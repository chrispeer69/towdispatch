# =====================================================================
# TowCommand Pro — Environment Configuration
# Copy to .env (and apps/api/.env / apps/web/.env.local) before running.
# =====================================================================

# ----- Core -----
NODE_ENV=development
LOG_LEVEL=debug

# ----- Database (Postgres 16 + PostGIS via docker-compose) -----
# App connections use the limited app_user role (RLS-enforcing).
# Migrations and ops connect with the superuser DATABASE_ADMIN_URL.
POSTGRES_USER=towcommand
POSTGRES_PASSWORD=towcommand_dev_pw
POSTGRES_DB=towcommand
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgres://app_user:app_user_dev_pw@localhost:5432/towcommand
DATABASE_ADMIN_URL=postgres://towcommand:towcommand_dev_pw@localhost:5432/towcommand

APP_USER_PASSWORD=app_user_dev_pw
APP_ADMIN_PASSWORD=app_admin_dev_pw

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- API -----
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ----- JWT -----
# 32+ random bytes recommended in production
JWT_ACCESS_SECRET=change-me-access-secret-please-rotate-in-production
JWT_REFRESH_SECRET=change-me-refresh-secret-please-rotate-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=towcommand
JWT_AUDIENCE=towcommand-api

# ----- Mail (mailhog locally) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@towcommand.local

# ----- Sentry (placeholder) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ----- Mapbox (placeholder) -----
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder
MAPBOX_SECRET_TOKEN=sk.placeholder

# ----- Stripe (placeholder) -----
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
