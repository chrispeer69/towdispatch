# =====================================================================
# Tow Dispatch — Environment Configuration
# Copy to .env (and apps/api/.env / apps/web/.env.local) before running.
# =====================================================================

# ----- Core -----
NODE_ENV=development
LOG_LEVEL=debug

# ----- Database (Postgres 16 + PostGIS via docker-compose) -----
# App connections use the limited app_user role (RLS-enforcing).
# Migrations and ops connect with the superuser DATABASE_ADMIN_URL.
POSTGRES_USER=towdispatch
POSTGRES_PASSWORD=towdispatch_dev_pw
POSTGRES_DB=towdispatch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgres://app_user:app_user_dev_pw@localhost:5432/towdispatch
DATABASE_ADMIN_URL=postgres://towdispatch:towdispatch_dev_pw@localhost:5432/towdispatch

APP_USER_PASSWORD=app_user_dev_pw
APP_ADMIN_PASSWORD=app_admin_dev_pw

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- API -----
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ----- JWT -----
# 32+ random bytes recommended in production. Generate with:
#   openssl rand -base64 48 | tr -d '=+/' | cut -c1-48
# Rotation: docs/runbooks/secrets-rotation.md §1
JWT_ACCESS_SECRET=change-me-access-secret-please-rotate-in-production
JWT_REFRESH_SECRET=change-me-refresh-secret-please-rotate-in-production
JWT_MFA_SECRET=change-me-mfa-challenge-secret-please-rotate-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=towdispatch
JWT_AUDIENCE=towdispatch-api

# Postgres connection pool size per API process. 20 is fine through ~3 replicas
# on a 100-connection Postgres. Bump when scaling horizontally.
DATABASE_POOL_MAX=20

# 32+ hex/base64 chars; AES-256-GCM key for users.totp_secret_encrypted at rest.
# Rotation requires a coordinated re-encrypt (see secrets-rotation.md §6).
TOTP_ENCRYPTION_KEY=change-me-totp-encryption-key-please-rotate-in-production

# ----- Mail (mailhog locally; SendGrid SMTP relay in prod) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=Tow Dispatch <no-reply@towdispatch.local>

# ----- Sentry (placeholder) -----
# Leave SENTRY_DSN empty to disable. In production, set to your Sentry
# project DSN. RELEASE_TAG is stamped on every event — wire it from the
# CI git SHA so each deploy is identifiable in the Sentry UI.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
RELEASE_TAG=dev

# ----- Datadog (optional alternate to Sentry) -----
# Empty DD_API_KEY disables Datadog. dd-trace bootstraps if set.
DD_API_KEY=
DD_ENV=development
DD_SERVICE=towdispatch-api

# ----- Observability thresholds -----
# Slow query log fires above SLOW_QUERY_THRESHOLD_MS at WARN with the
# parameterised SQL and scrubbed params. SLOW_ENDPOINT_THRESHOLD_MS does
# the same for whole HTTP requests.
SLOW_QUERY_THRESHOLD_MS=250
SLOW_ENDPOINT_THRESHOLD_MS=1000

# ----- Response compression -----
# Compress responses larger than this many bytes (br/gzip/deflate). Tiny
# bodies skip compression to avoid spending CPU for negligible savings.
COMPRESSION_MIN_BYTES=1024

# ----- Content-Security-Policy allow-list -----
# Comma-separated origins added to default-src 'self'. Document what each
# entry is for in SESSION_17A_REPORT.md so future ops know what to keep.
CSP_CONNECT_SRC=https://api.stripe.com,https://api.mapbox.com,https://*.ingest.sentry.io
CSP_SCRIPT_SRC=https://js.stripe.com
CSP_IMG_SRC=https://*.mapbox.com,https://*.tile.openstreetmap.org,data:,blob:
CSP_FRAME_SRC=https://js.stripe.com,https://hooks.stripe.com

# ----- Rate limits -----
# Global Redis-backed throttler. Per-route @Throttle decorators override.
# Auth endpoints layer per-email caps inside AuthService.
RATE_LIMIT_BURST_TTL_SECONDS=60
RATE_LIMIT_BURST_LIMIT=30
RATE_LIMIT_SUSTAINED_TTL_SECONDS=900
RATE_LIMIT_SUSTAINED_LIMIT=300

# ----- Mapbox (placeholder) -----
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder
MAPBOX_SECRET_TOKEN=sk.placeholder

# ----- Stripe (Session 11) -----
# When STRIPE_SECRET_KEY is empty the payments module falls back to the
# in-memory stub. Set the live keys in production. Rotation: §4 of
# docs/runbooks/secrets-rotation.md.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# ----- QuickBooks Online (Session 12) -----
# When QBO_CLIENT_ID is empty the accounting module uses the stub provider
# end-to-end (OAuth, sync, webhooks). Rotation: §9 of secrets-rotation.md.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_SANDBOX=true
QBO_TOKEN_ENCRYPTION_KEY=change-me-qbo-token-encryption-key-please-rotate-in-production
QBO_WEBHOOK_VERIFIER_TOKEN=verifier-token-default-dev-value

# ----- Twilio (tracking SMS) -----
# Empty = stub provider; tracking SMS messages get logged instead of sent.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_BASE_URL=

# ----- Tracking link defaults -----
# Default SMS body uses Handlebars-style placeholders. The link TTL bounds
# how long tracking URLs stay live (so old job links don't leak).
TRACKING_SMS_DEFAULT_BODY=Your tow truck is on the way. Track live: {{tracking_url}} — {{tenant_name}}
TRACKING_LINK_TTL_HOURS=24
