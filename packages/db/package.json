{
  "name": "@ustowdispatch/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "studio": "drizzle-kit studio",
    "reset": "tsx src/reset.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ustowdispatch/shared": "workspace:*",
    "argon2": "0.41.1",
    "dotenv": "16.4.5",
    "drizzle-orm": "0.36.4",
    "pg": "8.13.1",
    "postgres": "3.4.5",
    "uuidv7": "1.0.2"
  },
  "devDependencies": {
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
