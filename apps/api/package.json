{
  "name": "@ustowdispatch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/vite-node/dist/cli.mjs --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "start": "node dist/apps/api/src/main.js",
    "start:prod": "node dist/apps/api/src/main.js",
    "migrate:prod": "pnpm --filter @ustowdispatch/db run migrate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1048.0",
    "@aws-sdk/s3-request-presigner": "3.1048.0",
