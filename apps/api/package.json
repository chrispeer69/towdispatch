    "@nest-lab/throttler-storage-redis": "1.1.0",
    "@nestjs/common": "10.4.13",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.13",
    "@nestjs/platform-fastify": "10.4.13",
    "@nestjs/throttler": "6.2.1",
    "@sendgrid/mail": "8.1.4",
    "@socket.io/redis-adapter": "8.3.0",
    "@towdispatch/db": "workspace:*",
    "@towdispatch/shared": "workspace:*",
    "argon2": "0.41.1",
    "csv-parse": "5.5.6",
    "drizzle-orm": "0.36.4",
    "libphonenumber-js": "1.11.20",
    "fastify": "4.28.1",
