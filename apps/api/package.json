{
  "name": "@towdispatch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/vite-node/dist/cli.mjs --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "start": "node dist/apps/api/src/main.js",
    "start:prod": "node dist/apps/api/src/main.js",
    "migrate:prod": "pnpm --filter @towdispatch/db run migrate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/compress": "7.0.3",
    "@fastify/cookie": "9.4.0",
