      "in_transit_at": ["in_transit_at"],
      "dropped_at": ["dropped_at"],
      "cleared_at": ["cleared_at"],
      "total_charged": ["total_charged", "total"],
      "driver_commission": ["driver_commission", "commission"],
      "notes": ["notes", "call_notes"]
    },
    "impounds": {
      "external_id": ["towbook_id", "id"],
      "vehicle_towbook_id": ["vehicle_towbook_id", "vehicle_id"],
      "impound_date": ["impound_date"],
      "yard_name": ["yard_name", "yard"],
      "hold_type": ["hold_type"],
      "daily_rate": ["daily_rate"],
      "release_date": ["release_date"],
      "release_reason": ["release_reason"],
      "personal_property_inventory": ["personal_property_inventory", "inventory"]
