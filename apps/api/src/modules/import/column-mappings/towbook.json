{
  "version": "1.0",
  "source": "towbook",
  "_comment": "Maps Towbook CSV column names to the importer's canonical field names. If a real Towbook export uses different headers, edit this file rather than the importer code. Every value is a string array — first-match-wins so multiple aliases are supported per canonical field.",
  "files": {
    "customers": {
      "external_id": ["towbook_id", "id"],
      "name": ["name", "customer_name"],
      "phone_primary": ["phone_primary", "phone", "phone1"],
      "phone_secondary": ["phone_secondary", "phone2", "mobile"],
      "email": ["email", "email_address"],
      "street_address": ["street_address", "address", "street"],
      "city": ["city"],
      "state": ["state"],
      "zip": ["zip", "postal_code", "zip_code"],
      "account_type": ["account_type", "type"],
      "billing_terms": ["billing_terms", "terms"],
      "credit_limit": ["credit_limit"],
      "coi_expiration": ["coi_expiration", "coi_expires"],
      "created_date": ["created_date", "created_at"]
    },
    "vehicles": {
      "external_id": ["towbook_id", "id"],
      "customer_towbook_id": ["customer_towbook_id", "customer_id"],
      "year": ["year"],
      "make": ["make"],
      "model": ["model"],
      "color": ["color"],
      "plate": ["plate", "license_plate"],
      "plate_state": ["plate_state", "license_state"],
      "vin": ["vin"],
      "notes": ["notes"]
    },
    "calls": {
      "external_id": ["towbook_id", "id", "call_id"],
