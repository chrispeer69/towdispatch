      "partial_fee_amount": ["partial_fee_amount", "partial_fee"],
      "partial_fee_reason": ["partial_fee_reason"]
    },
    "attachments_manifest": {
      "towbook_id": ["towbook_id", "call_id"],
      "filename": ["filename", "file"],
      "type": ["type", "kind"]
    }
  },
