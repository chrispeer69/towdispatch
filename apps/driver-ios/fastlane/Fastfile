default_platform(:ios)

platform :ios do
  desc "Run all unit and UI tests"
  lane :test do
    run_tests(
      project: "TowCommandDriver.xcodeproj",
      scheme: "TowCommandDriver",
      devices: ["iPhone 15"]
    )
  end

  desc "Push a build to TestFlight"
  lane :beta do
    setup_ci if ENV['CI']
    increment_build_number(xcodeproj: "TowCommandDriver.xcodeproj")
    build_app(
      project: "TowCommandDriver.xcodeproj",
      scheme: "TowCommandDriver",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/fastlane"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Internal Session 6 build."
    )
  end

  desc "Ship to App Store"
  lane :release do
    setup_ci if ENV['CI']
    increment_build_number(xcodeproj: "TowCommandDriver.xcodeproj")
    build_app(
      project: "TowCommandDriver.xcodeproj",
      scheme: "TowCommandDriver",
      configuration: "Release",
      export_method: "app-store"
    )
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      skip_screenshots: true,
      skip_metadata: false
    )
  end
end
