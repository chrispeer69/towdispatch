NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mapbox access token for the live dispatch map. The dispatch board
# detects the placeholder and shows a "Mapbox token not configured" panel
# instead of crashing. Replace with a real public token from
# https://account.mapbox.com/access-tokens/ to enable the map pane.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder

# Sentry (web) — separate project from the API's SENTRY_DSN. Leave empty to
# disable the SDK: builds and runtime are no-ops without a DSN. next.config.mjs
# mirrors this into NEXT_PUBLIC_SENTRY_DSN_WEB for the browser bundle.
SENTRY_DSN_WEB=
# Optional environment label reported with each event (defaults to NODE_ENV).
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_ENV=
# Source-map upload at build time — CI/CD only. Without an auth token the
# build skips upload, keeping local + e2e + PR builds offline-safe.
SENTRY_ORG=
SENTRY_PROJECT_WEB=
SENTRY_AUTH_TOKEN=
