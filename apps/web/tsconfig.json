{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "noEmit": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ustowdispatch/shared": ["../../packages/shared/src/index.ts"],
      "@ustowdispatch/shared/*": ["../../packages/shared/src/*"],
      "@ustowdispatch/db": ["../../packages/db/src/index.ts"],
      "@ustowdispatch/db/*": ["../../packages/db/src/*"],
      "@ustowdispatch/ui": ["../../packages/ui/src/index.ts"],
      "@ustowdispatch/ui/*": ["../../packages/ui/src/*"]
    },
    "allowJs": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
