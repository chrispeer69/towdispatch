{
  "name": "@ustowdispatch/e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "smoke:prod": "SMOKE_RUN_AGAINST_PROD=1 playwright test production-smoke.spec.ts --project=chromium",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.1",
    "@ustowdispatch/shared": "workspace:*",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.4.0",
    "playwright-lighthouse": "4.0.0",
    "typescript": "7.0.2"
  }
}
