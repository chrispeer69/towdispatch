# Production smoke harness env.
#
# Copy to apps/e2e/.env.smoke and fill in. `pnpm smoke:prod` loads this file
# automatically (via playwright.config.ts, Node built-in loader — no extra
# dependency). NEVER commit the filled-in .env.smoke; only this .example.

# ---------------------------------------------------------------------------
# Required — targets + identity
# ---------------------------------------------------------------------------
PROD_API_URL=https://api.towcommand.cloud
PROD_WEB_URL=https://app.towcommand.cloud

# Base inbox. Each run plus-addresses a unique tag (you+smoke-<id>@domain) so
# repeated runs never collide and mail still routes to the same inbox.
SMOKE_TEST_EMAIL=you@example.com

# Display name for the synthetic tenant. The run suffixes it for uniqueness
# and prefixes it with [SMOKE-CLEANUP] at the end so it's easy to find/purge.
SMOKE_TEST_TENANT_NAME=Smoke Test Towing

# Must satisfy the server password policy.
SMOKE_TEST_PASSWORD=CorrectHorse-Battery-9!

# ---------------------------------------------------------------------------
# Optional — deliberate-500 leg (GET /_debug/boom)
# ---------------------------------------------------------------------------
# Must match SMOKE_DEBUG_TOKEN on the API environment, AND that environment
# must set SMOKE_DEBUG_ERROR_ENABLED=true. If unset (or the route isn't
# deployed/enabled) the 500 + Sentry legs soft-skip — the core flow still runs.
SMOKE_DEBUG_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Sentry verification leg
# ---------------------------------------------------------------------------
# A Sentry internal-integration / auth token with `project:read`, plus the org
# and project slugs. When absent, the 500 is still asserted but the event is
# not matched in Sentry (soft-skip). SENTRY_API_URL defaults to sentry.io;
# override only for self-hosted.
SENTRY_API_URL=https://sentry.io
SENTRY_API_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
