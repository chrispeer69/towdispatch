{
  "name": "ustowdispatch",
  "version": "0.1.0",
  "private": true,
  "description": "US Tow DISPATCH — multi-tenant SaaS operating system for the towing industry",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "build": "pnpm -r run build",
    "start": "node scripts/railway-start.mjs",
    "start:all": "pnpm -r --parallel --filter=./apps/* run start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @ustowdispatch/web run test:e2e",
    "db:generate": "pnpm --filter @ustowdispatch/db run generate",
    "db:migrate": "pnpm --filter @ustowdispatch/db run migrate",
    "db:seed": "pnpm --filter @ustowdispatch/db run seed",
    "db:seed:demo": "pnpm --filter @ustowdispatch/db run seed:demo",
    "db:studio": "pnpm --filter @ustowdispatch/db run studio",
    "db:reset": "pnpm --filter @ustowdispatch/db run reset",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.9.3",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.0.6",
      "fastify": "^4.29.1",
      "lodash": "^4.17.21",
      "cookie": "^0.7.0",
      "send": "^0.19.0",
      "serve-static": "^1.16.0",
      "path-to-regexp": "^6.3.0"
    }
  }
}
