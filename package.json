{
  "name": "ustowdispatch",
  "version": "0.1.0",
  "private": true,
  "description": "US Tow DISPATCH — multi-tenant SaaS operating system for the towing industry",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "build": "pnpm -r run build",
    "start": "node scripts/railway-start.mjs",
    "start:all": "pnpm -r --parallel --filter=./apps/* run start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test && vitest run",
    "test:e2e": "pnpm --filter @ustowdispatch/web run test:e2e",
    "compliance:check": "tsx scripts/compliance/check.ts",
    "compliance:collect": "tsx scripts/compliance/collect-evidence.ts",
    "compliance:type2-check": "tsx scripts/compliance/type2-check.ts",
    "test:scripts": "vitest run",
    "smoke:prod": "pnpm --filter @ustowdispatch/e2e run smoke:prod",
    "db:generate": "pnpm --filter @ustowdispatch/db run generate",
    "db:migrate": "pnpm --filter @ustowdispatch/db run migrate",
    "db:seed": "pnpm --filter @ustowdispatch/db run seed",
    "db:seed:demo": "pnpm --filter @ustowdispatch/db run seed:demo",
    "db:studio": "pnpm --filter @ustowdispatch/db run studio",
    "db:reset": "pnpm --filter @ustowdispatch/db run reset",
    "ops:failover-check": "tsx scripts/ops/failover-check.ts",
    "ops:promote-secondary": "tsx scripts/ops/promote-secondary.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "pg": "8.13.1",
    "rimraf": "6.1.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "@types/pg": "8.11.10",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.0.6",
      "fastify": "^5.7.0",
      "lodash": "^4.18.1",
      "nodemailer": "^8.0.0",
      "cookie": "^0.7.0",
      "send": "^0.19.0",
      "serve-static": "^1.16.0",
      "path-to-regexp": "^6.3.0",
      "handlebars": "^4.7.9",
      "vite": "^5.4.15",
      "esbuild": "^0.25.0",
      "vitest": "^4.1.7",
      "ws": "^8.17.1",
      "@fastify/middie": "^9.3.2",
      "nodemailer": "^6.10.0",
      "qs": "^6.13.0",
      "engine.io-client": "^6.6.3"
    }
  }
}
